{
  "compilerOptions": {
    "target": "ES2020",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "outDir": "dist",
    "rootDir": ".",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "types": ["node"]
  },
  "references": [
    { "path": "../packages/core" }
  ],
  "include": ["./*.ts", "./construct-pattern/*.ts"],
  "exclude": ["node_modules", "dist", "concepts.ts"]
}
